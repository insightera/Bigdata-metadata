<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  HariSekhon/hbase entrypoint replaces zookeeper:2181 -> localhost:2181 on startup.
  Hostname entries help RegionServer/Master advertise the Docker service name so other
  containers (e.g. Atlas) can reach RPC (default 16020).
-->
<configuration>
  <property>
    <name>hbase.cluster.distributed</name>
    <value>true</value>
  </property>
  <property>
    <name>hbase.rootdir</name>
    <value>/hbase-data</value>
  </property>
  <property>
    <name>hbase.zookeeper.quorum</name>
    <value>zookeeper:2181</value>
  </property>
  <property>
    <name>hbase.master.hostname</name>
    <value>hbase</value>
  </property>
  <property>
    <name>hbase.regionserver.hostname</name>
    <value>hbase</value>
  </property>
</configuration>
